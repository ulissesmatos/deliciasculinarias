apps/pocketbase/pb_data/
apps/pocketbase/pb_data_local
apps/pocketbase/pb_data_local/

# Build output (rebuilt inside Docker)
apps/web/dist
apps/web/.vite

# Git
.git
.gitignore
.gitattributes

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Editor
.vscode
.idea
*.swp
*.swo

# Dev and test
*.test.*
*.spec.*
